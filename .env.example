# Ascend – Azure credentials
# Copy this file to .env and fill in the values.
#
# Used by:
#   - Makefile targets (make az-login, make admin-setup, etc.)
#   - Integration test suite (via python-dotenv)
#
# If .env is absent the Makefile admin targets will error out, and the
# test suite falls back to ambient credentials (az login, env vars,
# managed identity) through DefaultAzureCredential.

# --- Required for integration tests ---

# Azure subscription containing the AKS cluster
AZURE_SUBSCRIPTION_ID=

# Resource group containing the AKS cluster
AZURE_RESOURCE_GROUP=

# Name of the AKS cluster used for test runs
AZURE_AKS_CLUSTER_NAME=

# Azure Storage account used for blob I/O
AZURE_STORAGE_ACCOUNT=

# Azure Container Registry for runtime images
AZURE_CONTAINER_REGISTRY=

# Username for the .ascend.yaml config (defaults to "integration-test" if unset)
AZURE_USERNAME=

# --- Service principal credentials (optional locally, required in CI) ---
# If omitted locally, DefaultAzureCredential falls back to az login.

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
